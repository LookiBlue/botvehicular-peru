# ──────────────────────────────────────────────
# BOT VEHICULAR PERU — Variables de Entorno
# ──────────────────────────────────────────────
# Copia este archivo a ".env" y rellena los valores.
# NUNCA subas el archivo ".env" a GitHub.

# ── Telegram ──────────────────────────────────
# Obtenlo de @BotFather en Telegram → /newbot
TELEGRAM_BOT_TOKEN=TU_TOKEN_AQUI

# ── Supabase ──────────────────────────────────
# Panel de Supabase → Settings → API
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Configuración del Bot ─────────────────────
# Créditos gratis al registrarse por primera vez
FREE_CREDITS=5

# Horas que dura el caché de una consulta antes de renovarse
CACHE_HOURS=24

# ── Seguridad ─────────────────────────────────
# Token secreto para verificar que el webhook viene de Telegram
# Puedes generar uno aleatorio: openssl rand -hex 32
WEBHOOK_SECRET=TU_SECRETO_AQUI

# ── APESEG (SOAT) ─────────────────────────────
# Token Bearer para la API de APESEG (consulta de SOAT por placa).
# Para obtenerlo:
#   1. Registrate en https://webapp.apeseg.org.pe
#   2. Abre DevTools (F12) → Network → consulta una placa
#   3. Copia el valor del header "Authorization: Bearer XXXXX"
# Opcional: si no se configura, el scraper intentará sin token
# (puede funcionar desde IPs de servidor cloud como Vercel)
APESEG_TOKEN=
